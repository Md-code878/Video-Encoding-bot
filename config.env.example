# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Admin Configuration (comma-separated user IDs)
ADMIN_IDS=123456789

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/videoencoderbot?retryWrites=true&w=majority
DB_NAME=videoencoderbot

# Log Channel (channel ID where bot logs activities)
LOG_CHANNEL=-1001234567890

# FFmpeg Settings
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Download/Upload Limits (in bytes) — 2GB default
MAX_FILE_SIZE=2147483648

# Worker count (concurrent encodes)
MAX_WORKERS=2

# Temp directory for processing
TEMP_DIR=./downloads
